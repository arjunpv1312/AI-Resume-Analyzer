{
  "manifest_version": 3,
  "name": "AI ATS Analyzer",
  "short_name": "ATS AI",
  "version": "1.0.0",
  "description": "Analyze your resume against job descriptions.",
  "start_url": "/",
  "display": "standalone",
  "theme_color": "#14b8a6",
  "icons": [
    {
      "src": "/favicon.ico",
      "sizes": "64x64 32x32 24x24 16x16",
      "type": "image/x-icon"
    },
    {
      "src": "/icon-192.png",
      "type": "image/png",
      "sizes": "192x192"
    },
    {
      "src": "/icon-512.png",
      "type": "image/png",
      "sizes": "512x512"
    }
  ]
}
